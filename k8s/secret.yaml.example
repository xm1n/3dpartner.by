# Скопируйте в secret.yaml и подставьте реальные значения.
# secret.yaml в .gitignore — не коммитить.
#
# S3_ACCESS_KEY / S3_SECRET_KEY — учётные данные MinIO (медиатека Payload хранится в S3/MinIO).
# В ConfigMap заданы S3_ENDPOINT, S3_BUCKET, S3_REGION; ключи — только здесь.
apiVersion: v1
kind: Secret
metadata:
  name: 3dpartner-secret
  namespace: 3dpartner
type: Opaque
stringData:
  POSTGRES_PASSWORD: "CHANGE_PASSWORD"
  DATABASE_URL: "postgresql://payload:CHANGE_PASSWORD@postgres:5432/3dpartner"
  PAYLOAD_SECRET: "CHANGE_ME_AT_LEAST_32_CHARS_RANDOM_STRING"
  # MinIO (S3) — для медиа-файлов Payload
  S3_ACCESS_KEY: "minioadmin"
  S3_SECRET_KEY: "CHANGE_MINIO_PASSWORD"
  REDIS_URL: "redis://redis:6379"
